<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black_mate"
    android:orientation="vertical">

    <!-- Banner de Contexto del Partido -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        app:cardCornerRadius="16dp"
        app:cardBackgroundColor="@color/surface"
        app:strokeColor="#333333"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/tvChatMatchPlace"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Complejo El Campito"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:textStyle="bold"/>
                <TextView
                    android:id="@+id/tvChatMatchStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="9/10 confirmados • Viernes 21:00"
                    android:textColor="@color/verde_neon"
                    android:textSize="11sp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/llChatAvatars"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvChatMensajes"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        android:clipToPadding="false"/>

    <!-- Barra de Herramientas del Chat -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingHorizontal="12dp"
        android:layout_marginBottom="8dp">
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <com.google.android.material.chip.Chip
                android:id="@+id/chipConfirmar"
                style="@style/Widget.MaterialComponents.Chip.Action"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Confirmado ✅"
                app:chipBackgroundColor="#1E3A1E"
                android:textColor="@color/verde_neon"
                app:chipStrokeColor="@color/verde_neon"
                app:chipStrokeWidth="1dp"
                android:layout_marginEnd="8dp"/>
            <com.google.android.material.chip.Chip
                android:id="@+id/chipTarde"
                style="@style/Widget.MaterialComponents.Chip.Action"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Llego tarde ⏰"
                app:chipBackgroundColor="#3A3A1E"
                android:textColor="#FFD700"
                android:layout_marginEnd="8dp"/>
            <com.google.android.material.chip.Chip
                android:id="@+id/chipNoVoy"
                style="@style/Widget.MaterialComponents.Chip.Action"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No voy ❌"
                app:chipBackgroundColor="#3A1E1E"
                android:textColor="#FF4444"/>
        </LinearLayout>
    </HorizontalScrollView>

    <!-- Input de Chat -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:background="@color/surface"
        android:gravity="center_vertical">
        <ImageButton
            android:id="@+id/btnChatAttach"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_input_add"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="@color/gray_text"/>
        <EditText
            android:id="@+id/etChatMessage"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Escribe algo..."
            android:textColorHint="@color/gray_text"
            android:textColor="@color/white"
            android:background="@drawable/bg_chat_input"
            android:padding="12dp"
            android:layout_marginHorizontal="8dp"
            android:textSize="14sp"/>
        <ImageButton
            android:id="@+id/btnChatSend"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@android:drawable/ic_menu_send"
            android:background="@drawable/bg_circle_green"
            app:tint="@color/black_mate"
            android:padding="10dp"/>
    </LinearLayout>
</LinearLayout>
