<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black_mate">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Organizar Partido"
                android:textColor="@color/verde_neon"
                android:textSize="24sp"
                android:textStyle="bold"/>
            <ProgressBar
                android:id="@+id/pbCreate"
                style="?android:attr/progressBarStyleSmall"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:visibility="gone"
                android:indeterminateTint="@color/verde_neon"/>
        </RelativeLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Lugar"
            android:layout_marginBottom="16dp"
            app:boxStrokeColor="@color/verde_neon"
            app:hintTextColor="@color/verde_neon"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etLugar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:inputType="text"/>
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Fecha y Hora"
            android:layout_marginBottom="16dp"
            app:boxStrokeColor="@color/verde_neon"
            app:hintTextColor="@color/verde_neon"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etFecha"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:inputType="text"/>
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Precio por persona"
            android:layout_marginBottom="16dp"
            app:boxStrokeColor="@color/verde_neon"
            app:hintTextColor="@color/verde_neon"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPrecio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:inputType="numberDecimal"/>
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Alias para transferencia"
            android:layout_marginBottom="16dp"
            app:boxStrokeColor="@color/verde_neon"
            app:hintTextColor="@color/verde_neon"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etAlias"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:inputType="text"/>
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tipo de Partido"
            android:textColor="@color/white"
            android:layout_marginBottom="8dp"/>

        <RadioGroup
            android:id="@+id/rgTipoPartido"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">
            <RadioButton
                android:id="@+id/rbF5"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fútbol 5 (10)"
                android:textColor="@color/white"
                android:buttonTint="@color/verde_neon"
                android:checked="true"/>
            <RadioButton
                android:id="@+id/rbF7"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fútbol 7 (14)"
                android:textColor="@color/white"
                android:layout_marginStart="16dp"
                android:buttonTint="@color/verde_neon"/>
        </RadioGroup>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGuardarPartido"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="CREAR Y NOTIFICAR"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="12dp"
            android:backgroundTint="@color/verde_cancha"/>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
