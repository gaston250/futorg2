<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black_mate">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="futorg"
                android:textColor="@color/verde_neon"
                android:textSize="28sp"
                android:textStyle="bold"
                android:layout_centerVertical="true"/>
            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_alignParentEnd="true"
                android:src="@drawable/ic_soccer_ball"
                app:tint="@color/verde_cancha" />
        </RelativeLayout>

        <!-- ALERTA CLIMA -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardClima"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:visibility="gone"
            app:cardBackgroundColor="#441111"
            app:strokeColor="#FF0000"
            app:strokeWidth="1dp"
            app:cardCornerRadius="12dp">
            <TextView
                android:id="@+id/tvClimaAviso"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp"
                android:text="⚠️ ALERTA DE LLUVIA"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="12sp"
                android:gravity="center"/>
        </com.google.android.material.card.MaterialCardView>

        <!-- Próximo Partido -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardBackgroundColor="@color/surface"
            app:strokeColor="@color/verde_cancha"
            app:strokeWidth="1dp"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PRÓXIMO PARTIDO"
                        android:textColor="@color/verde_neon"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"/>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:orientation="horizontal">
                        <ImageButton
                            android:id="@+id/btnMap"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:src="@android:drawable/ic_dialog_map"
                            app:tint="@color/verde_neon"
                            android:layout_marginEnd="8dp"/>
                        <ImageButton
                            android:id="@+id/btnShare"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:src="@android:drawable/ic_menu_share"
                            app:tint="@color/verde_neon"/>
                    </LinearLayout>
                </RelativeLayout>

                <TextView
                    android:id="@+id/tvLugar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Complejo El Campito"
                    android:textColor="@color/white"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginTop="8dp"/>

                <TextView
                    android:id="@+id/tvFechaHora"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Viernes 21:00 hs"
                    android:textColor="@color/gray_text"
                    android:layout_marginTop="4dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="12dp">
                    <TextView
                        android:id="@+id/tvPrecio"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="$2.500"
                        android:textColor="@color/verde_neon"
                        android:textSize="18sp"
                        android:textStyle="bold"/>

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipAlias"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Copiá Alias"
                        app:chipIcon="@android:drawable/ic_menu_edit"
                        app:chipBackgroundColor="@color/surface"
                        android:textColor="@color/white"
                        app:chipStrokeColor="@color/verde_neon"
                        app:chipStrokeWidth="1dp"
                        android:textSize="11sp"/>
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnMeSumo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="¡ME SUMO!"
                    android:textStyle="bold"
                    app:cornerRadius="10dp"
                    android:backgroundTint="@color/verde_neon"
                    android:textColor="@color/black_mate"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Jugadores Confirmados y Tesorería -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">
            <TextView
                android:id="@+id/tvCountConfirmados"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Confirmados (0/10)"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold"/>
            <TextView
                android:id="@+id/tvTotalRecaudado"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Total: $0"
                android:textColor="@color/verde_neon"
                android:textSize="12sp"
                android:layout_marginEnd="8dp"/>
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCerrarPartido"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CERRAR RANKING"
                android:textColor="@color/verde_neon"
                android:textSize="10sp"
                android:visibility="gone"/>
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvConfirmados"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"/>

        <!-- Votación MVP -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardVotacionMVP"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:visibility="gone"
            app:cardCornerRadius="20dp"
            app:cardBackgroundColor="@color/surface"
            app:strokeColor="@color/verde_neon"
            app:strokeWidth="1dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PARTIDO FINALIZADO"
                    android:textColor="@color/verde_neon"
                    android:textSize="12sp"
                    android:textStyle="bold"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Elegí al MVP del partido"
                    android:textColor="@color/white"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginTop="8dp"/>
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnVotarMVP"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="VOTAR JUGADOR"
                    app:cornerRadius="10dp"
                    android:backgroundTint="@color/verde_neon"
                    android:textColor="@color/black_mate"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Top Goleadores"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvRankingHome"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"/>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
